# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Provider (only minimax)
AI_PROVIDER=minimax
NEXT_PUBLIC_AI_PROVIDER=minimax
AI_DEFAULT_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.chat

# Transcript fallback
SUPADATA_API_KEY=
SUPADATA_API_BASE=https://api.supadata.ai

# App
# Leave NEXT_PUBLIC_APP_URL empty in Vercel preview deployments so resolveAppUrl() falls back to VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret (for /api/cron/cleanup-rate-limits)
CRON_SECRET=
