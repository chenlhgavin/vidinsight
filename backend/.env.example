ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_AUTH_TOKEN=
# Claude Sonnet (default text model)
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
# Backward-compatible alias (deprecated)
CLAUDE_MODEL=
# Claude Opus
CLAUDE_OPUS_MODEL=claude-opus-4-6

# Qwen (DashScope)
DASHSCOPE_API_KEY=sk-xxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Supadata (optional YouTube transcript / metadata source)
SUPADATA_API_KEY=

# Storage
CONVERSATION_DATABASE_URL=mysql+aiomysql://video:video@127.0.0.1:3306/video

# Runtime
MAX_RETRIES=3
RETRY_DELAYS=2,5,10
MAX_CONTEXT_MESSAGES=20

# CORS
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Authentication (set AUTH_ENABLED=true to enable)
AUTH_ENABLED=false
AUTH_JWT_SECRET=  # generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_TOKEN_EXPIRY_HOURS=72
AUTH_COOKIE_SECURE=auto  # auto|true|false — auto detects HTTPS from request
AUTH_COOKIE_DOMAIN=
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=vidinsight
